#!/bin/bash

# ==============================================================================
# CONFIGURATION
# ==============================================================================

BASE_DIR="$HOME/Videos/Recordings"
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
SESSION_DIR="$BASE_DIR/$TIMESTAMP"
LOG_DIR="$SESSION_DIR/logs"

mkdir -p "$SESSION_DIR"
mkdir -p "$LOG_DIR"

# Files
FILE_SCREEN="$SESSION_DIR/raw_screen.mkv"
FILE_WEBCAM="$SESSION_DIR/raw_webcam.mkv"
FILE_MIC_WAV="$SESSION_DIR/raw_mic.wav"
FILE_SYS_WAV="$SESSION_DIR/raw_sys.wav"
FILE_FINAL="$SESSION_DIR/final_render.mkv"

# --- Visual Settings ---
CAM_WIDTH=320
BORDER_WIDTH=6
MARGIN=30
ZOOM_FACTOR=0.7         
REC_W=640
REC_H=480

# ==============================================================================
# 1. HARDWARE SELECTION
# ==============================================================================
if [ -f "/usr/bin/ffmpeg" ]; then FFMPEG_CMD="/usr/bin/ffmpeg"; else FFMPEG_CMD="ffmpeg"; fi

clear
echo "========================================================"
echo "    PERFORMANCE & SYNC RECORDER (LAG FIX)               "
echo "========================================================"

# --- Monitor ---
echo "[1/4] Detecting Monitors..."
MON_NAMES=()
MON_GEOMS=()
while read -r line; do
    NAME=$(echo "$line" | awk '{print $1}')
    GEOM=$(echo "$line" | grep -oP '[0-9]+x[0-9]+\+[0-9]+\+[0-9]+')
    if [ ! -z "$GEOM" ]; then MON_NAMES+=("$NAME"); MON_GEOMS+=("$GEOM"); fi
done < <(xrandr | grep " connected")

if [ ${#MON_NAMES[@]} -eq 0 ]; then echo "Error: No monitors."; exit 1; fi

for i in "${!MON_NAMES[@]}"; do echo "  [$i] ${MON_NAMES[$i]} (${MON_GEOMS[$i]})"; done
read -p "Select Monitor [0]: " MON_INDEX
[ -z "$MON_INDEX" ] && MON_INDEX=0
SELECTED_GEOM=${MON_GEOMS[$MON_INDEX]}
SCREEN_RES=$(echo "$SELECTED_GEOM" | cut -d'+' -f1)
OFFSET_X=$(echo "$SELECTED_GEOM" | cut -d'+' -f2)
OFFSET_Y=$(echo "$SELECTED_GEOM" | cut -d'+' -f3)

# --- Webcam ---
echo -e "\n[2/4] Scanning Webcams..."
WEBCAMS=($(ls /dev/video* 2>/dev/null))
if [ ${#WEBCAMS[@]} -eq 0 ]; then WEBCAM_DEVICE=""; else
    for i in "${!WEBCAMS[@]}"; do echo "  [$i] ${WEBCAMS[$i]}"; done
    read -p "Select Webcam [0] (Enter to skip): " CAM_INDEX
    [ ! -z "$CAM_INDEX" ] && WEBCAM_DEVICE=${WEBCAMS[$CAM_INDEX]}
fi

# --- Audio ---
echo -e "\n[3/4] Mic Setup..."
mapfile -t MIC_SOURCES < <(pactl list sources short | grep -v "\.monitor" | awk '{print $2}')
for i in "${!MIC_SOURCES[@]}"; do echo "  [$i] ${MIC_SOURCES[$i]}"; done
read -p "Select Mic [0]: " MIC_INDEX
[ ! -z "$MIC_INDEX" ] && MIC_SOURCE=${MIC_SOURCES[$MIC_INDEX]}

echo -e "\n[4/4] System Audio Setup..."
mapfile -t SYS_SOURCES < <(pactl list sources short | grep "\.monitor" | awk '{print $2}')
for i in "${!SYS_SOURCES[@]}"; do echo "  [$i] ${SYS_SOURCES[$i]}"; done
read -p "Select Sys Audio [0]: " SYS_INDEX
[ ! -z "$SYS_INDEX" ] && SYS_SOURCE=${SYS_SOURCES[$SYS_INDEX]}

echo "--------------------------------------------------------"
read -p "Press [ENTER] to START RECORDING..."

# ==============================================================================
# 2. RECORDING (SINGLE PROCESS + LIGHTWEIGHT CODECS)
# ==============================================================================

CMD_INPUTS=""
CMD_MAPS=""
INPUT_INDEX=0

# --- Input 0: Screen ---
# Use x11grab. High buffer.
CMD_INPUTS="$CMD_INPUTS -thread_queue_size 4096 -f x11grab -video_size $SCREEN_RES -framerate 30 -i :0.0+$OFFSET_X,$OFFSET_Y"

# Map 0 -> libx264 (Main Quality)
# -tune zerolatency prevents lag/buffering
CMD_MAPS="$CMD_MAPS -map $INPUT_INDEX:v -c:v libx264 -preset ultrafast -tune zerolatency -qp 0 -y $FILE_SCREEN"
INPUT_INDEX=$((INPUT_INDEX+1))

# --- Input 1: Webcam (Optional) ---
if [ ! -z "$WEBCAM_DEVICE" ]; then
    CMD_INPUTS="$CMD_INPUTS -thread_queue_size 4096 -f v4l2 -input_format yuyv422 -video_size ${REC_W}x${REC_H} -framerate 30 -i $WEBCAM_DEVICE"
    
    # LAG FIX: Map 1 -> mpeg4 (Fast/Light CPU Usage)
    # q:v 5 gives decent quality for a small webcam box without killing CPU
    CMD_MAPS="$CMD_MAPS -map $INPUT_INDEX:v -c:v mpeg4 -q:v 5 -y $FILE_WEBCAM"
    INPUT_INDEX=$((INPUT_INDEX+1))
fi

# --- Input 2: Mic (Optional) ---
if [ ! -z "$MIC_SOURCE" ]; then
    CMD_INPUTS="$CMD_INPUTS -thread_queue_size 4096 -f pulse -i $MIC_SOURCE"
    CMD_MAPS="$CMD_MAPS -map $INPUT_INDEX:a -c:a pcm_s16le -y $FILE_MIC_WAV"
    INPUT_INDEX=$((INPUT_INDEX+1))
fi

# --- Input 3: Sys (Optional) ---
if [ ! -z "$SYS_SOURCE" ]; then
    CMD_INPUTS="$CMD_INPUTS -thread_queue_size 4096 -f pulse -i $SYS_SOURCE"
    CMD_MAPS="$CMD_MAPS -map $INPUT_INDEX:a -c:a pcm_s16le -y $FILE_SYS_WAV"
    INPUT_INDEX=$((INPUT_INDEX+1))
fi

# --- EXECUTE ---
LOG_MASTER="$LOG_DIR/master_record.log"
FULL_CMD="$FFMPEG_CMD -hide_banner -loglevel error -stats $CMD_INPUTS $CMD_MAPS"

# Run in background
$FULL_CMD > "$LOG_MASTER" 2>&1 &
PID_MASTER=$!

sleep 2
if ! kill -0 $PID_MASTER 2>/dev/null; then
    echo "FATAL: Recording failed immediately."
    echo "Check logs: $LOG_MASTER"
    tail -n 5 "$LOG_MASTER"
    exit 1
fi

echo ">> RECORDING IN PROGRESS... (PID: $PID_MASTER)"
echo ">> Sync Mode: Single-Process | CPU Mode: Optimized (MPEG4/x264)"
echo ">> Press [ENTER] to STOP."
read -p ""

# ==============================================================================
# 3. STOP
# ==============================================================================
echo "Stopping..."
kill -SIGINT $PID_MASTER
wait $PID_MASTER 2>/dev/null
echo "Files saved. Starting Merge..."

# ==============================================================================
# 4. MERGE (ZOOM + OVERLAY)
# ==============================================================================

INPUT_FLAGS="-i $FILE_SCREEN"
INPUT_COUNT=1
VIDEO_MAP="-map 0:v" 

# --- Webcam Overlay ---
if [ -s "$FILE_WEBCAM" ]; then
    INPUT_FLAGS="$INPUT_FLAGS -i $FILE_WEBCAM"
    
    YW=$((CAM_WIDTH + BORDER_WIDTH * 2))
    CAM_HEIGHT=$(echo "$CAM_WIDTH * 9 / 16" | bc)
    YH=$((CAM_HEIGHT + BORDER_WIDTH * 2))
    
    ZOOM_FILTER="crop=iw*${ZOOM_FACTOR}:ih*${ZOOM_FACTOR},scale=${CAM_WIDTH}:${CAM_HEIGHT}"
    VIDEO_FILTER="[1:v]${ZOOM_FILTER}[cam_zoomed];color=c=yellow:s=${YW}x${YH}[yellow_bg];[yellow_bg][cam_zoomed]overlay=(W-w)/2:(H-h)/2[pip];[0:v][pip]overlay=main_w-overlay_w-${MARGIN}:main_h-overlay_h-${MARGIN}[v_out]"
    
    VIDEO_MAP="-map [v_out]"
    INPUT_COUNT=$((INPUT_COUNT+1))
else
    VIDEO_FILTER=""
fi

# --- Audio Mixing ---
AUDIO_FLAGS=""
AUDIO_FILTER_PARTS=""
HAS_AUDIO=0

if [ -s "$FILE_MIC_WAV" ]; then
    INPUT_FLAGS="$INPUT_FLAGS -i $FILE_MIC_WAV"
    AUDIO_FILTER_PARTS="${AUDIO_FILTER_PARTS}[${INPUT_COUNT}:a]"
    INPUT_COUNT=$((INPUT_COUNT+1))
    HAS_AUDIO=1
fi

if [ -s "$FILE_SYS_WAV" ]; then
    INPUT_FLAGS="$INPUT_FLAGS -i $FILE_SYS_WAV"
    AUDIO_FILTER_PARTS="${AUDIO_FILTER_PARTS}[${INPUT_COUNT}:a]"
    INPUT_COUNT=$((INPUT_COUNT+1))
    HAS_AUDIO=1
fi

if [ "$HAS_AUDIO" -eq 1 ]; then
    NUM_AUDIOS=$(echo "$AUDIO_FILTER_PARTS" | grep -o "\\[" | wc -l)
    if [ "$NUM_AUDIOS" -gt 1 ]; then
        AUDIO_FILTER="${AUDIO_FILTER_PARTS}amix=inputs=${NUM_AUDIOS}:duration=longest:dropout_transition=2[a_out]"
        AUDIO_MAP="-map [a_out]"
    else
        AUDIO_INDEX=$((INPUT_COUNT-1))
        AUDIO_MAP="-map ${AUDIO_INDEX}:a"
        AUDIO_FILTER=""
    fi
else
    AUDIO_MAP=""
    AUDIO_FILTER=""
fi

# --- Final Render ---
COMPLEX_FILTER=""
if [ ! -z "$VIDEO_FILTER" ]; then
    COMPLEX_FILTER="$VIDEO_FILTER"
    if [ ! -z "$AUDIO_FILTER" ]; then
        COMPLEX_FILTER="${COMPLEX_FILTER};${AUDIO_FILTER}"
    fi
elif [ ! -z "$AUDIO_FILTER" ]; then
    COMPLEX_FILTER="$AUDIO_FILTER"
fi

CMD_FILTER=""
[ ! -z "$COMPLEX_FILTER" ] && CMD_FILTER="-filter_complex \"$COMPLEX_FILTER\""

echo "Rendering final video..."
# Final render uses high quality x264 since it's post-processing (time doesn't matter)
CMD="$FFMPEG_CMD $INPUT_FLAGS $CMD_FILTER $VIDEO_MAP $AUDIO_MAP -c:v libx264 -preset fast -crf 23 -c:a aac -b:a 192k -shortest \"$FILE_FINAL\""

eval $CMD

echo "========================================================"
echo "COMPLETE"
echo "Video: $FILE_FINAL"
echo "========================================================"
